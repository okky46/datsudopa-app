{
  "name": "datsudopa-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@expo-google-fonts/zen-maru-gothic": "^0.4.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-font": "~56.0.7",
    "expo-linking": "~56.0.14",
    "expo-notifications": "~56.0.18",
    "expo-router": "~56.2.11",
    "expo-screen-orientation": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-video": "~56.1.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-google-mobile-ads": "^16.4.0",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.0",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "~56.0.15",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "start:lan": "expo start --lan",
    "start:localhost": "expo start --localhost",
    "start:tunnel": "expo start --tunnel",
    "android": "expo start --android",
    "android:emu": "set REACT_NATIVE_PACKAGER_HOSTNAME=10.0.2.2&& expo start --lan --port 8081",
    "android:emu:open": "powershell -NoProfile -Command \"& \\\"$env:LOCALAPPDATA\\Android\\Sdk\\platform-tools\\adb.exe\\\" shell am start -a android.intent.action.VIEW -d exp://10.0.2.2:8081\"",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "dev:android": "expo run:android",
    "dev:ios": "expo run:ios",
    "typecheck": "tsc --noEmit"
  },
  "private": true
}
